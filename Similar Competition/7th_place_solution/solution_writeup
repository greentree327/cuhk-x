Simply concatenate IMU and TOF features along the feature_dim, and treat them as image data with ch_size=1.

# imu.shape = (seq_len, imu_ch)
# tof.shape = (seq_len, tof_ch)
img = np.concatenate([imu, tof], axis=1) # (seq_len, imu_ch+tof_ch)
img = cv2.resize(img, (1024, 512)) # (seq_len=512, feat_size=1024)
img = img.reshape(1, 512, 1024) # (1, seq_len, feat_size) as (ch, h, w)

